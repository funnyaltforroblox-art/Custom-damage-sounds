-- Helper to retrieve all MP3 paths from a specific tier folder
local function getSoundPool(tier)
    local folderPath = config.baseFolder .. "/" .. tier
    local files = listfiles(folderPath)
    local mp3Pool = {}
    
    for _, path in ipairs(files) do
        if path:sub(-4):lower() == ".mp3" then
            table.insert(mp3Pool, path)
        end
    end
    return mp3Pool
end

-- Audio Player that picks a random file from the target pool
local function playRandomDamageSound(tier)
    local pool = getSoundPool(tier)
    if #pool == 0 then return end -- No sounds inside this folder
    
    -- Pick a random track from the array
    local randomTrackPath = pool[math.random(1, #pool)]
    
    local success, assetId = pcall(function()
        return getcustomasset(randomTrackPath)
    end)
    
    if success and assetId then
        local sound = Instance.new("Sound")
        sound.SoundId = assetId
        sound.Volume = 1.5
        sound.Parent = game:GetService("SoundService")
        sound:Play()
        sound.Ended:Connect(function() sound:Destroy() end)
    end
end

-- Monitor Character Health
local player = game:GetService("Players").LocalPlayer
local function listenToHealth(character)
    local humanoid = character:WaitForChild("Humanoid", 10)
    if not humanoid then return end
    
    local lastHealth = humanoid.Health
    humanoid.HealthChanged:Connect(function(currentHealth)
        if currentHealth < lastHealth and lastHealth > 0 then
            local damage = lastHealth - currentHealth
            if damage > 0 and damage <= config.lowThresh then
                playRandomDamageSound("low")
            elseif damage > config.lowThresh and damage <= config.medThresh then
                playRandomDamageSound("medium")
            elseif damage > config.medThresh then
                playRandomDamageSound("high")
            end
        end
        lastHealth = currentHealth
    end)
end

if player.Character then listenToHealth(player.Character) end
player.CharacterAdded:Connect(listenToHealth)

