local function createRow(labelTxt, val, yPos)
    local label = Instance.new("TextLabel", MenuFrame)
    label.Size = UDim2.new(0, 150, 0, 25); label.Position = UDim2.new(0, 10, 0, yPos)
    label.BackgroundTransparency = 1; label.Text = labelTxt
    label.TextColor3 = Color3.new(1,1,1); label.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("TextBox", MenuFrame)
    box.Size = UDim2.new(0, 80, 0, 25); box.Position = UDim2.new(0, 180, 0, yPos)
    box.BackgroundColor3 = Color3.fromRGB(35,35,40); box.Text = tostring(val)
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    return box
end

